{
  "name": "opencode-search",
  "version": "0.0.2",
  "description": "OpenCode plugin that provides web search tools using Google CSE, DuckDuckGo, Bluesky, and Standard.site.",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "search",
    "web-search",
    "google",
    "duckduckgo",
    "bluesky",
    "atproto",
    "standard-site"
  ],
  "homepage": "https://github.com/whaaaley/opencode-search#readme",
  "bugs": {
    "url": "https://github.com/whaaaley/opencode-search/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whaaaley/opencode-search.git"
  },
  "license": "MIT",
  "author": "Dustin Dowell",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/search.js",
      "types": "./dist/search.d.ts"
    }
  },
  "main": "./dist/search.js",
  "types": "./dist/search.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "fmt": "bun run dprint fmt",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mozilla/readability": "0.5.0",
    "jsdom": "26.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.1.12",
    "@types/bun": "latest",
    "@types/jsdom": "27.0.0",
    "dprint": "^0.49.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.13.7"
  }
}
